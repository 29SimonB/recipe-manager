PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173
DB_PATH=./data/recipe-manager.db
# Set to the built frontend's dist folder to have the backend also serve the
# frontend (single process/port). Leave unset during local dev, where the
# Vite dev server (localhost:5173) serves the frontend separately.
FRONTEND_DIST_PATH=../frontend/dist
